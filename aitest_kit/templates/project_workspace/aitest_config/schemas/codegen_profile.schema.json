{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitest.local/schemas/codegen_profile.schema.json",
  "title": "Codegen Profile",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "module_type": {
      "type": "string",
      "minLength": 1
    },
    "profile_scope": {
      "type": "string",
      "enum": ["case_suite"]
    },
    "parent_module": {
      "type": "string",
      "minLength": 1
    },
    "parent_profile": {
      "type": "string",
      "minLength": 1
    },
    "suite": {
      "type": "string",
      "minLength": 1
    },
    "knowledge_refs": {
      "type": "object"
    },
    "default_fixture": {
      "$ref": "#/$defs/identifier"
    },
    "default_object": {
      "$ref": "#/$defs/identifier"
    },
    "default_case_setup": {
      "$ref": "#/$defs/caseFlowCallStep"
    },
    "assertion_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "pattern": {
            "type": "string"
          },
          "regex": {
            "type": "string"
          },
          "template": {
            "type": "string"
          },
          "extract_vars": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "params": {
            "type": "object"
          }
        }
      }
    },
    "variables": {
      "$ref": "#/$defs/profileVariables"
    },
    "request_overrides": {
      "type": "object",
      "patternProperties": {
        "^TC-[A-Z0-9]+-[0-9]+$": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "extra_imports": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "case_fixtures": {
      "type": "object",
      "patternProperties": {
        "^TC-[A-Z0-9]+-[0-9]+$": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "case_bodies": {
      "type": "object",
      "patternProperties": {
        "^TC-[A-Z0-9]+-[0-9]+$": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "case_flows": {
      "type": "object",
      "patternProperties": {
        "^TC-[A-Z0-9]+-[0-9]+$": {
          "$ref": "#/$defs/caseFlow"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "dottedCall": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*$"
    },
    "variableName": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "profileVariables": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaults": {
          "type": "object",
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*$": {
              "$ref": "#/$defs/profileVariableSource"
            }
          },
          "additionalProperties": false
        },
        "cases": {
          "type": "object",
          "patternProperties": {
            "^TC-[A-Z0-9]+-[0-9]+$": {
              "type": "object",
              "patternProperties": {
                "^[A-Za-z_][A-Za-z0-9_]*$": {
                  "$ref": "#/$defs/profileVariableSource"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    },
    "profileVariableSource": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["env"],
          "properties": {
            "env": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["value"],
          "properties": {
            "value": true
          }
        }
      ]
    },
    "caseFlow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps"],
      "properties": {
        "fixture": {
          "type": "string",
          "minLength": 1
        },
        "object": {
          "$ref": "#/$defs/identifier"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/caseFlowStep"
          }
        }
      }
    },
    "caseFlowStep": {
      "oneOf": [
        {
          "$ref": "#/$defs/caseFlowCallStep"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["assign", "expr"],
          "properties": {
            "assign": {
              "$ref": "#/$defs/identifier"
            },
            "expr": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["assert"],
          "properties": {
            "assert": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["comment"],
          "properties": {
            "comment": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "caseFlowCallStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["call"],
      "properties": {
        "call": {
          "$ref": "#/$defs/dottedCall"
        },
        "args": {
          "type": "array"
        },
        "kwargs": {
          "type": "object"
        },
        "save_as": {
          "$ref": "#/$defs/identifier"
        }
      }
    }
  }
}
